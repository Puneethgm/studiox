# Production environment for Project-X.
# Copy this file to deploy/.env and fill in real values. Do NOT commit deploy/.env.
#
# After editing, run:  bash deploy/deploy.sh

# ---- Postgres (used by both postgres container and api) ----
POSTGRES_USER=projectx
POSTGRES_PASSWORD=CHANGE_ME_long_random_string
POSTGRES_DB=projectx

# ---- Auth ----
# Long random string (32+ chars). Rotate independently per environment.
JWT_SECRET=CHANGE_ME_at_least_32_random_chars_xxxxxxxxxxxxxxxxxxxx

# ---- Token encryption (channel access tokens at rest) ----
# 32-byte AES-256 key, base64-encoded. REQUIRED — api refuses to boot without it.
# Generate fresh on this box with:  openssl rand -base64 32
# Rotating this key requires re-encrypting every channel_accounts row.
TOKEN_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_base64_32

# Seeded super admin (created/refreshed by `seed` on every deploy — idempotent).
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ---- Cookies ----
# Set to your bare hostname/IP. When you add a domain, change to that.
COOKIE_DOMAIN=13.250.175.113
# Flip to true once HTTPS is on (otherwise browsers reject the cookie).
COOKIE_SECURE=false

# ---- Public-facing URL ----
# Used to render shareable campaign links and to set the API CORS allowlist.
# Update when you add a domain.
PUBLIC_FORM_BASE_URL=http://13.250.175.113

# ---- Google Sheets (optional — leave blank to disable) ----
# Place the service-account JSON at deploy/secrets/google-credentials.json,
# then set the spreadsheet id below. See docs/SETUP_GOOGLE_SHEETS.md.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB=Leads
